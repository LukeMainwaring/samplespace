# Environment
ENVIRONMENT=development

# OpenAI (for Pydantic AI agent)
OPENAI_API_KEY=sk-...

# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=samplespace
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Sample library (absolute path to your local sample directory, e.g. Splice, Loopcloud)
SAMPLE_LIBRARY_DIR=/path/to/your/samples

# Pydantic Logfire
LOGFIRE_TOKEN=your-logfire-token
